# Accepts n (int) from standard input and writes n * n to standard output.
.text
    readi    r0           # read n
    calln    r12 square   # result = square(n)
    writei   r13          # write result
    halt                  # halt the machine

# int square(int n):
#   input : r0 = n
#   output: r13 = n * n

square:
    mul      r13 r0 r0    # output = n * n
    jumpr    r12          # jump to caller
