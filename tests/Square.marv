# Accepts n (int) from standard input and writes n * n to standard output.
.text
    readi    r0           # read n
    jsr      ra square    # result = square(n)
    writei   rv           # write result
    halt                  # halt the machine

# int square(int n):
#   input : r0 = n
#   output: r13 = n * n

square:
    muli     rv r0 r0     # output = n * n
    jra      ra           # jump to caller
