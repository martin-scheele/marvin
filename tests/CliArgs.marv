.text
start:
    lda     r0 argv             # r0 := $argv
    alen    r1 r0               # r1 := len(argv)
    seti    r2 0                # i := 0
loop:
    jge     r2 r1 end_loop      # jump if i >= len(argv)
    alds    r3 r0 r2            # r3 := argv[i] (addr of first arg)
    writes  r3                  # write argv[i]
    inci    r2 1                # i++
    jump    loop                # next outer iteration
end_loop:
    halt

