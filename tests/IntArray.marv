.text
setup:
    aneww gp 4          # init array to len 4
    copy r0 gp          # r1 = addr
    inci gp 18          # increment gp
    alen r1 r0
    seti r2 0           # index = 0
end_setup:
init:
    astw r2 r0 r2       # addr[index] = index
    inci r2 1           # index += 1
    jlt r2 r1 init      # continue loop
end_init:
    seti r2 0           # index = 0
print:
    aldw r3 r0 r2       # val = addr[index]
    writei r3           # print val
    inci r2 1           # index += 1
    jlt r2 r1 print     # continue loop
end_print:
    halt
