.text
setup:
    seti r0 4           # len = 4
    aneww gp 4          # init array to len 4
    copy r1 gp          # r1 = addr
    inci gp 18          # increment gp
    seti r2 0           # index = 0
init:
    jeqz r0 end_init    # if i == 0, end loop
    astw r2 r1 r2       # addr[index] = index
    inci r2 1           # index += 1
    inci r0 -1          # i -= 1
    jump init           # continue loop
end_init:
    alen r0 r1          # i = addr.len
    seti r2 0           # index = 0
print:
    jeqz r0 end_print   # if r0 == 0, end loop
    aldw r3 r1 r2       # val = addr[index]
    writei r3           # print val
    inci r2 1           # index += 1
    inci r0 -1          # i -= 1
    jump print          # continue loop
end_print:
    halt
