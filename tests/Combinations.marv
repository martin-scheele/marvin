# Accepts n (int) and k (int) from standard input and writes C(n, k) = n!/(k!(n-k)!) to standard output.
.text
      readi    r3            # read n
      readi    r4            # read k
      copy     r5 r3         # r5 = n
      jsr      ra factorial  # n! = factorial(n)
      copy     r7 rv         # r7 = n!
      copy     r5 r4         # r5 = k
      jsr      ra factorial  # k! = factorial(k)
      divi     r7 r7 rv      # r7 = n!/k!
      subi     r5 r3 r4      # r5 = n - k
      jsr      ra factorial  # (n-k)! = factorial(n-k)
      divi     r7 r7 rv      # r7 = n!/(k!(n-k)!)
      writei   r7            # write n!/(k!(n-k)!)
      halt                   # halt the machine

# int factorial(int n):
#   input:  r5 = n
#   output: rv = n!
#   temps:  r6

factorial:
      seti     rv 1          # output = 1
      copy     r6 r5         # i = n
loop:
      jeqz     r6 return     # if i = 0 jump to 19
      muli     rv rv r6      # output = output * i
      inci     r6 -1         # i = i - 1
      jump     loop          # jump to loop
return:
      jra      ra            # jump to caller
