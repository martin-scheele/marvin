# Accepts n (int) from standard input and writes n! (computed recursively) to standard output.
.text
    readi     r3            # read n
    pushw     r3 sp         # mem[sp++] = n
    jsr       ra factorial  # n! = factorial(n)
    inci      sp -4         # sp = sp - 4
    writei    rv            # write n!
    halt                    # halt the machine

# int factorial(int n):
#   input : r3 = n
#   output: rv = n!
#   temps: r4, r5

# Save ra and fp, and set fp to sp.
factorial:
    pushw     ra sp           # mem[sp--] = ra
    pushw     fp sp           # mem[sp--] = fp
    copy      fp sp           # fp = sp

    # Save registers used.
    pushw     r3 sp           # mem[sp--] = r3
    pushw     r4 sp           # mem[sp--] = r4
    pushw     r5 sp           # mem[sp--] = r5

    loadnw    r3 fp 12        # n = mem[fp + 12]
    jnez      r3 factorialRec # if n != 0 jump to 16 (recursive step),
                              # else fall through (base case)

    # Base case.
    seti      rv 1            # output = 1
    jump      restore         # jump to restore

# Recursive step.
factorialRec:
    copy      r5 r3           # r5 = n
    inci      r5 -1           # n = n - 1
    pushw     r5 sp           # mem[sp--] = n - 1
    jsr       ra factorial    # (n-1)! = factorialRec(n-1)
    inci      sp 4            # sp = sp + 4
    muli      rv r3 rv        # n! = n(n-1)!

restore:
    # Restore registers used.
    popw      r5 sp           # r5 = mem[++sp]
    popw      r4 sp           # r4 = mem[++sp]
    popw      r3 sp           # r3 = mem[++sp]

    # Restore fp and ra, and jump to ra (caller).
    popw      fp sp           # fp = mem[++sp]
    popw      ra sp           # ra = mem[++sp]
    jra       ra              # jump to caller
